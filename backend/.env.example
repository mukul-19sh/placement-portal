# Copy this file to .env and fill in your values
# Local development only - Render will use Environment Variables in the dashboard

# Database (Render sets DATABASE_URL automatically when you add PostgreSQL)
# For local PostgreSQL: postgresql://user:password@localhost:5432/placement_db
# Leave empty or omit for local SQLite
DATABASE_URL=

# JWT secret - REQUIRED in production! Generate a random string.
# Example: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this

# Optional
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMTP / Email (for transactional emails)
# e.g. for Gmail SMTP (use App Passwords, not your real password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Cloud Storage Configuration
# Set to 'true' to use cloud storage, 'false' for local storage
USE_CLOUD_STORAGE=false
# Options: local, s3, cloudinary
STORAGE_TYPE=local

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Cloudinary Configuration (if using Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Security Configuration
# Maximum login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5
# Account lockout duration in minutes
LOGIN_COOLDOWN_MINUTES=15

# Rate Limiting
# General API rate limit (requests per hour)
RATE_LIMIT_REQUESTS=1000
# Rate limit window in seconds
RATE_LIMIT_WINDOW=3600

# Profile view rate limiting (views per day per student)
PROFILE_VIEW_LIMIT=50
# Profile view window in seconds (24 hours)
PROFILE_VIEW_WINDOW=86400

# Email verification token expiration (minutes)
EMAIL_TOKEN_EXPIRE_MINUTES=15
